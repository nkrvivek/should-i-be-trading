# Supabase (required for auth + multi-tenant features)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Local dev fallback (used when Supabase is not configured)
VITE_RADON_API_URL=http://localhost:8321
VITE_WS_URL=ws://localhost:8765

# Development-only provider fallbacks.
# Do not expose these in production builds. Production traffic should use authenticated edge functions.
VITE_ANTHROPIC_API_KEY=
VITE_EXA_API_KEY=

# Finnhub (free — insider trading, market data)
# Get your free key at https://finnhub.io/register
VITE_FINNHUB_API_KEY=

# Unusual Whales (premium — dark pool, insider, congress, options flow)
# Get your token at https://unusualwhales.com/api
VITE_UW_TOKEN=

# Stripe (publishable key only — secret key goes in Supabase Edge Function secrets)
VITE_STRIPE_PUBLISHABLE_KEY=

# Server-side API keys (set in Supabase Edge Function secrets, not in .env)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_MONTHLY_PRICE_ID=
# STRIPE_PRO_YEARLY_PRICE_ID=
# STRIPE_ENT_MONTHLY_PRICE_ID=
# STRIPE_ENT_YEARLY_PRICE_ID=
# FRED_API_KEY=
# FINNHUB_API_KEY=
# ALPHA_VANTAGE_API_KEY=
