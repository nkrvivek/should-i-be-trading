# Supabase (required for auth + multi-tenant features)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Local dev fallback (used when Supabase is not configured)
VITE_RADON_API_URL=http://localhost:8321
VITE_WS_URL=ws://localhost:8765

# Direct API keys (local dev only — in production, users store their own keys via Settings)
VITE_ANTHROPIC_API_KEY=
VITE_EXA_API_KEY=

# Finnhub (free — insider trading, market data)
# Get your free key at https://finnhub.io/register
VITE_FINNHUB_API_KEY=

# Server-side API keys (set in Supabase Edge Function secrets, not in .env)
# FRED_API_KEY=
# FINNHUB_API_KEY=
# ALPHA_VANTAGE_API_KEY=
